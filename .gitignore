# Copyrighted game data — never committed. We only keep derived asm/config.
iso/
disc/orig/
ghidra_export/
steps/

# Build output
build/

# Generated progress report. PROGRESS.md (human report) IS tracked; this
# machine-readable companion is regenerated by `make progress` each build.
progress.json
progress.shield.json

# splat/build intermediates regenerated by `make split` / `make build`
config/*.d
config/spyro.main.syms.ld
# Artifact (tools/build_main.sh regenerates it each build).
# config/text_layout.json is intentionally TRACKED — the disc-free CI build reads
# it (it is produced by `make split`, which CI does not run).
config/spyro.main.slots.ld
# Per-overlay splat configs are regenerated from config/overlays.json by `make split`.
config/overlays/*.yaml
config/overlays/*.d
# NOTE: config/overlays/*.ld and *.undefined_*.auto.txt are intentionally TRACKED
# (committed). They are splat-generated link artifacts (derived metadata, no game
# data) that let CI relink every overlay from committed asm without the disc. The
# dev regenerates them via `make split` and commits them with asm changes.

# Original disc + extracted originals
*.bin
*.cue

# Toolchain repos cloned by `make setup` (gcc 2.7.2 is built from source inside
# the Docker image, so nothing lands here on the host).
tools/maspsx/
tools/m2c/
tools/asm-differ/
tools/decomp-permuter/
tools/mkpsxiso/

# Python tooling venv (created by `make setup`)
.venv/

# Python / OS cruft
__pycache__/
.DS_Store

# Local scratch notes
notes.md

.ruff_cache/
